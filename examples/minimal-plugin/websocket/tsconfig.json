{
   "compilerOptions": {
      "target": "ES2020",
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "strict": true,
      "esModuleInterop": true,
      "sourceMap": true,
      "outDir": "dist",
      "rootDir": "src",
      "skipLibCheck": true,
      "lib": ["ES2020"],
      "resolveJsonModule": true
   },
   "include": ["src/**/*.ts"],
   "exclude": ["node_modules"]
}
