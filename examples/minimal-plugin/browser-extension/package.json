{
   "name": "minimal-browser-extension-puryfi-plugin",
   "version": "0.1.0",
   "description": "A minimal browser extension plugin for PuryFi using the Plugin SDK.",
   "private": true,
   "scripts": {
      "watch": "webpack --mode=development --watch --config config/webpack.config.js",
      "build": "webpack --mode=production --config config/webpack.config.js",
      "dev:firefox": "web-ext run --source-dir build/firefox --target firefox-desktop",
      "dev:firefox:watch": "npm run watch & web-ext run --source-dir build/firefox --target firefox-desktop --watch-file build/firefox"
   },
   "devDependencies": {
      "copy-webpack-plugin": "^10.2.4",
      "ts-loader": "^9.5.1",
      "typescript": "^5.7.3",
      "web-ext": "^8.0.0",
      "webpack": "^5.104.1",
      "webpack-cli": "^4.10.0"
   },
   "dependencies": {
      "@pury-fi/plugin-sdk": "file:../../../"
   }
}
