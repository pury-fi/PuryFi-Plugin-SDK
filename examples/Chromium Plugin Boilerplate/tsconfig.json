{
   "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "strict": true,
      "esModuleInterop": true,
      "sourceMap": true,
      "outDir": "build",
      "rootDir": "src",
      "skipLibCheck": true,
      "lib": ["ES2020", "DOM"],
      "resolveJsonModule": true
   },
   "include": ["src/**/*.ts"],
   "exclude": ["node_modules", "build"]
}
