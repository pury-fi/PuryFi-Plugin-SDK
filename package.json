{
  "name": "puryfi-plugin-sdk",
  "version": "1.0.0",
  "description": "SDK for developing PuryFi plugins",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./dist/cjs/core/index.cjs",
  "module": "./dist/esm/core/index.js",
  "types": "./dist/esm/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/core/index.d.ts",
      "import": "./dist/esm/core/index.js",
      "require": "./dist/cjs/core/index.cjs"
    },
    "./browser": {
      "types": "./dist/esm/browser/index.d.ts",
      "import": "./dist/esm/browser/index.js",
      "require": "./dist/cjs/browser/index.cjs"
    },
    "./socket": {
      "types": "./dist/esm/socket/index.d.ts",
      "import": "./dist/esm/socket/index.js",
      "require": "./dist/cjs/socket/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "watch": "tsc -p tsconfig.esm.json --watch",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node ./scripts/rename-cjs.mjs",
    "build": "npm run build:esm && npm run build:cjs"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@types/chrome": "^0.1.36",
    "@types/firefox-webext-browser": "^143.0.0",
    "ws": "^8.19.0"
  }
}
